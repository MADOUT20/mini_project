# Public domain used by the frontend
DOMAIN=chaosfaction.xyz

# Next.js server-side rewrite target on the VPS
BACKEND_API_URL=http://127.0.0.1:8000

# FastAPI configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=production

# Frontend domain allowed to reach FastAPI
ALLOWED_ORIGINS=https://chaosfaction.xyz,https://www.chaosfaction.xyz

# Set this to your real network interface on the VPS, for example eth0 or ens3
CAPTURE_INTERFACE=eth0
